n=int(input("enter the value of n:"))
for i in range (1,n+1):
  print(i,end=" ")
print()
# output 
'''
  enter the value of n:4
  1 2 3 4 
'''
#--------------------------------------------------------
#with function 
def pattern(n):
  for i in range(1, n+1):
    print(i,end=" ")
  print()
n=int(input("enter value of n:"))
pattern(n)

# output 
'''
  enter the value of n:4
  1 2 3 4 
'''
